# TITANOS Git Ignore

# ── Runtime data directory ───────────────────────────────────────────────────
# The entire .titanos/ directory is runtime-generated; only committed examples
# or templates (if any) should be excluded explicitly.
.titanos/

# ── Logs ─────────────────────────────────────────────────────────────────────
logs/
*.log

# ── Python ───────────────────────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/
*.egg-info/
.venv/
venv/

# ── Build / dist artifacts ───────────────────────────────────────────────────
dist/
build/
release/
packaging/*.whl
packaging/*.tar.gz

# ── UI / Node ─────────────────────────────────────────────────────────────────
node_modules/
cypress/videos/
cypress/screenshots/
desktop-runtime/
desktop-ui/
scratch/
.cache/
.parcel-cache/
.next/

# ── Dev certs ────────────────────────────────────────────────────────────────
cert/*.pem

# ── OS / editor ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
